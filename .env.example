# Copy this file to ".env.local" and fill in your Supabase credentials.
# Get them at: https://supabase.com/dashboard → your project → Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_ANON_KEY_HERE

# If you leave these empty, the app runs in single-player mode (localStorage only).
# Fill them in to enable login, groups, leaderboard, and cloud sync.
